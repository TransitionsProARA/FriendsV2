{"style":{"mobile":{"align":"center"},"default":{}},"states":[],"interactions":[{"id":"5d375bf4-c596-4204-a672-1f6142c124d4","actions":{"b397052b-f967-4109-820e-209e2cfebb36":{"id":"b397052b-f967-4109-820e-209e2cfebb36","type":"copy-clipboard","value":{"code":"// Récupération de l'objet d'erreur\nconst errorObject = context.component?.props?.['3f9e7133-816b-4d18-9353-fe29d5138aa3'];\n\n// Fonction pour convertir un objet en texte lisible\nfunction objectToReadableText(obj, indent = 0) {\n    if (obj === null) return \"Aucune valeur\";\n    if (obj === undefined) return \"Non défini\";\n    \n    const spaces = \"  \".repeat(indent);\n    \n    if (typeof obj === \"string\") return `\"${obj}\"`;\n    if (typeof obj === \"number\") return obj.toString();\n    if (typeof obj === \"boolean\") return obj ? \"Oui\" : \"Non\";\n    \n    if (Array.isArray(obj)) {\n        if (obj.length === 0) return \"Liste vide\";\n        let result = \"Liste :\\n\";\n        obj.forEach((item, index) => {\n            result += `${spaces}  ${index + 1}. ${objectToReadableText(item, indent + 1)}\\n`;\n        });\n        return result.trim();\n    }\n    \n    if (typeof obj === \"object\") {\n        const keys = Object.keys(obj);\n        if (keys.length === 0) return \"Objet vide\";\n        \n        let result = \"\";\n        keys.forEach(key => {\n            const value = obj[key];\n            const readableKey = key.replace(/_/g, \" \").replace(/([A-Z])/g, \" $1\").toLowerCase();\n            const capitalizedKey = readableKey.charAt(0).toUpperCase() + readableKey.slice(1);\n            \n            result += `${spaces}${capitalizedKey} : ${objectToReadableText(value, indent + 1)}\\n`;\n        });\n        return result.trim();\n    }\n    \n    return obj.toString();\n}\n\n// Conversion de l'objet d'erreur en texte lisible\nif (!errorObject) {\n    return \"Aucune information d'erreur disponible\";\n}\n\n// Création d'un résumé de l'erreur\nlet errorSummary = \"=== DÉTAILS DE L'ERREUR ===\\n\\n\";\n\n// Ajout des informations principales si disponibles\nif (errorObject.message) {\n    errorSummary += `Message : ${errorObject.message}\\n`;\n}\nif (errorObject.code) {\n    errorSummary += `Code d'erreur : ${errorObject.code}\\n`;\n}\nif (errorObject.status) {\n    errorSummary += `Statut : ${errorObject.status}\\n`;\n}\nif (errorObject.type) {\n    errorSummary += `Type : ${errorObject.type}\\n`;\n}\n\nerrorSummary += \"\\n=== INFORMATIONS COMPLÈTES ===\\n\\n\";\nerrorSummary += objectToReadableText(errorObject);\n\nreturn errorSummary;","__wwtype":"js"}}},"trigger":"click","firstAction":"b397052b-f967-4109-820e-209e2cfebb36"}]},"content":{"default":{"tag":"h2","text":{"en":"Warning!"},"_ww-text_font":"var(--4b448574-e721-44d3-b6dd-8761766bd384, 700 16px/24px var(--ww-default-font-family, sans-serif))","_ww-text_text":{"en":{"code":"wwFormulas.ifEmpty(context.component?.props?.['errorMessage'],'Une erreur est survenue')","__wwtype":"f","defaultValue":"<div>Erreur !</div>"},"fr":{"code":"wwFormulas.ifEmpty(context.component?.props?.['errorMessage'],'Une erreur est survenue')","__wwtype":"f","defaultValue":"<div>Une erreur est survenue</div>"}},"_ww-text_color":"var(--b52e7045-77d4-4fad-ac67-d7d06a0aaf87,#1E293B)","_ww-text_fontSize":"24px","_ww-text_textAlign":"center","_ww-text_fontFamily":"var(--ww-default-font-family, sans-serif)","_ww-text_fontWeight":"700","_ww-text_lineHeight":"1.2"}},"name":"Warning Title","wwObjectBaseId":"d7904e9d-fc9a-4d80-9e32-728e097879ad","libraryComponentBaseId":null,"parentLibraryComponentId":"632a31db-1373-4202-b22a-d4dc73283c74"},"83798d37-c251-4a17-a953-2071bc5f87c3":{"uid":"83798d37-c251-4a17-a953-2071bc5f87c3","_state":{"style":{"default":{"margin":"0","maxWidth":"350px"}},"states":[],"interactions":[]},"content":{"mobile":{"_ww-text_textAlign":"center"},"default":{"tag":"p","text":{"en":null},"_ww-text_font":"var(--26e02088-3f7e-4fd0-9a51-ab1b2ec84f4f, 400 14px/21px var(--ww-default-font-family, san